{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/blog/(.*)", "dest": "/index.html" },
    { "src": "/blog", "dest": "/index.html" },
    { "src": "/reservation", "dest": "/index.html" },
    { "src": "/login", "dest": "/index.html" },
    { "src": "/admin/(.*)", "dest": "/index.html" },
    { "src": "/admin", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
