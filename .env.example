# Variables d'environnement - Vercel
# Ne JAMAIS commiter ce fichier
# Copie ce fichier en .env et remplis tes vraies clés

# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=votre_cle_publique_stripe_ici
STRIPE_SECRET_KEY=votre_cle_secrete_stripe_ici

# Firebase
VITE_FIREBASE_API_KEY=votre_cle_api_firebase_ici
VITE_FIREBASE_AUTH_DOMAIN=votre_projet.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=votre_projet
VITE_FIREBASE_STORAGE_BUCKET=votre_projet.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=votre_sender_id
VITE_FIREBASE_APP_ID=votre_app_id
